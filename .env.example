VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Security Settings (for Supabase Edge Functions) ─────────────────────────
# Comma-separated list of allowed CORS origins. Never use * in production.
# Example: https://app.yourdomain.com,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting (optional overrides for defaults in _shared/security.ts)
# RATE_LIMIT_MAX=100           # Max requests per window (default 100)
# RATE_LIMIT_WINDOW_SEC=60     # Window size in seconds (default 60)
# RATE_LIMIT_WEBHOOK_MAX=500   # Higher limit for Meta webhook events (default 500)

# WhatsApp / Meta
WHATSAPP_VERIFY_TOKEN=your-secret-webhook-verify-token
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# Google Sheets OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
ADMIN_EMAIL=support@yourdomain.com

# Meta Marketing
MARKETING_API_TOKEN=your-long-lived-marketing-token
META_AD_ACCOUNT_ID=your-ad-account-id
